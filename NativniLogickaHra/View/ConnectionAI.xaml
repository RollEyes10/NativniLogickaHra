<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:utils="clr-namespace:NativniLogickaHra.Utils"
             x:Class="NativniLogickaHra.View.ConnectionAI"
             Title="{Binding [Connection_Title], Source={x:Static utils:LocalizationHelper.Instance}}">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <Button Text="{Binding [Connection_InstructionBtn], Source={x:Static utils:LocalizationHelper.Instance}}"
                    Clicked="OnInstructionClicked"
                    BackgroundColor="#2D89EF"
                    TextColor="White"/>

            <Label Text="{Binding [Connection_SavedConnections], Source={x:Static utils:LocalizationHelper.Instance}}"
                   FontSize="22" FontAttributes="Bold"/>

            <CollectionView x:Name="ConnectionsList"
                            SelectionMode="Single"
                            SelectionChanged="OnConnectionSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,5" StrokeThickness="1" StrokeShape="RoundRectangle 10"
                                Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#444444}">
                            <VerticalStackLayout>
                                <Label Text="{Binding Provider}" FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Status}"   FontSize="12" TextColor="Gray"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{Binding [Connection_Detail], Source={x:Static utils:LocalizationHelper.Instance}}"
                   FontSize="22" FontAttributes="Bold"/>

            <Label Text="{Binding [Connection_Provider], Source={x:Static utils:LocalizationHelper.Instance}}"/>
            <Picker x:Name="ProviderPicker" SelectedIndexChanged="OnProviderChanged">
                <Picker.Items>
                    <x:String>Gemini</x:String>
                    <x:String>ChatGPT</x:String>
                    <x:String>Claude</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="{Binding [Connection_ApiKey], Source={x:Static utils:LocalizationHelper.Instance}}"/>
            <Entry x:Name="ApiKeyEntry"
                   Placeholder="{Binding [Connection_ApiKeyPlaceholder], Source={x:Static utils:LocalizationHelper.Instance}}"
                   IsPassword="True"/>

            <VerticalStackLayout x:Name="GeminiModePanel" IsVisible="False" Spacing="5">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="{Binding [Connection_GeminiMode], Source={x:Static utils:LocalizationHelper.Instance}}"
                           VerticalOptions="Center"/>
                    <CheckBox x:Name="PaidCheckBox"/>
                    <Label Text="{Binding [Connection_GeminiPaid], Source={x:Static utils:LocalizationHelper.Instance}}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="{Binding [Connection_GeminiInfo], Source={x:Static utils:LocalizationHelper.Instance}}"
                       FontSize="12" TextColor="Gray"/>
            </VerticalStackLayout>

            <Button Text="{Binding [Connection_Save], Source={x:Static utils:LocalizationHelper.Instance}}"
                    Clicked="OnSaveKeyClicked"/>

            <Button Text="{Binding [Connection_Delete], Source={x:Static utils:LocalizationHelper.Instance}}"
                    BackgroundColor="Red" TextColor="White"
                    Clicked="OnDeleteKeyClicked"/>

            <Label x:Name="StatusLabel"
                   HorizontalOptions="Center"
                   FontAttributes="Italic"
                   TextColor="Gray"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
