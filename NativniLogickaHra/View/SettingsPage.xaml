<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NativniLogickaHra.View.SettingsPage"
             Title="Nastavení">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label Text="Nastavení hry"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Jazyk -->
            <VerticalStackLayout>
                <Label Text="Jazyk aplikace:" />
                <Picker x:Name="LanguagePicker">
                    <Picker.Items>
                        <x:String>Čeština</x:String>
                        <x:String>English</x:String>
                    </Picker.Items>
                </Picker>
            </VerticalStackLayout>

            <!-- Hlasitost -->
            <VerticalStackLayout>
                <Label x:Name="VolumeLabel" Text="Hlasitost: 50 %" />
                <Slider x:Name="VolumeSlider"
                        Minimum="0"
                        Maximum="100"
                        Value="50"
                        ValueChanged="OnVolumeChanged" />
            </VerticalStackLayout>

            <!-- Obtížnost (manuální) -->
            <VerticalStackLayout>
                <Label Text="Obtížnost:" />
                <Picker x:Name="DifficultyPicker" SelectedIndexChanged="OnDifficultyChanged">
                    <Picker.Items>
                        <x:String>Easy</x:String>
                        <x:String>Normal</x:String>
                        <x:String>Hard</x:String>
                        <x:String>Custom</x:String>
                    </Picker.Items>
                </Picker>
            </VerticalStackLayout>

            <!-- AI adaptivní obtížnost -->
            <Frame Padding="15"
                   CornerRadius="10"
                   BorderColor="LightGray"
                   BackgroundColor="#F5F5F5">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Adaptivní obtížnost AI"
                           FontAttributes="Bold"
                           FontSize="15" />

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Aktuální úroveň:" VerticalOptions="Center" />
                        <Label x:Name="AiDifficultyLabel"
                               FontAttributes="Bold"
                               FontSize="15"
                               VerticalOptions="Center"
                               TextColor="#2D89EF" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="20">
                        <VerticalStackLayout>
                            <Label Text="Výhry" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
                            <Label x:Name="StatsWinsLabel" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="Prohry" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
                            <Label x:Name="StatsLossesLabel" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="Série" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
                            <Label x:Name="StatsStreakLabel" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="Úspěšnost" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
                            <Label x:Name="StatsWinRateLabel" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Button Text="Resetovat statistiky"
                            BackgroundColor="#E74C3C"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnResetStatsClicked" />

                </VerticalStackLayout>
            </Frame>

            <!-- Životy -->
            <VerticalStackLayout>
                <Label Text="Omezené životy:" />
                <Switch x:Name="LivesEnabledSwitch"
                        IsToggled="true"
                        Toggled="OnLivesToggled" />
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label x:Name="LivesLabel" Text="Počet životů: 5" />
                <Slider x:Name="LivesSlider"
                        Minimum="0"
                        Maximum="10"
                        Value="5"
                        ValueChanged="OnLivesChanged" />
            </VerticalStackLayout>

            <!-- Samohlásky -->
            <VerticalStackLayout>
                <Label x:Name="RequiredConsonantsLabel" Text="Souhlásky pro povolení samohlásek: 3" />
                <Slider x:Name="RequiredConsonantsSlider"
                        Minimum="0"
                        Maximum="10"
                        Value="3"
                        ValueChanged="OnRequiredConsonantsChanged" />
            </VerticalStackLayout>

            <Button Text="Uložit a zpět"
                    Margin="0,20,0,0"
                    Clicked="OnSaveClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
